        "no_action": 0
      },
      "tex_block": "\\begin{defmark}\n\\begin{Def}[$id$-separation]\n    Let $G=(J,V,E,L)$ be a CDMG and $A,B,C \\ins J \\cup V$ (not necessarily disjoint) subset of nodes.\n    We then say that:\n    \\begin{enumerate}\n        \\item \\emph{$A$ is $id$-separated from $B$ given $C$ in $G$}, in symbols:\n    \\[ A \\idPerp_G B \\given C,  \\]\n    if every walk from a node in $A$ to a node in $J \\cup B$ (sic!)\\footref{fn:why-J} is $C$-$d$-blocked by $C$.\n        \\item If that property does not hold we will write:\n            \\[ A \\nidPerp_G B \\given C.\\]\n        \\item We also define the special case:\n                \\[ A \\idPerp_G B \\qquad :\\iff \\qquad A \\idPerp_G B \\given \\emptyset.\\]\n        \\item For the special case $J = \\emptyset$---that is, if $G$ has no input nodes---$id$-separation is also called \\emph{$d$-separation}, and we write:\n          \\[A \\dPerp_G B \\given C := A \\idPerp_G B \\given C, \\qquad A \\ndPerp_G B \\given C := A \\nidPerp_G B \\given C.\\]\n          % claim_3_29\n          \\begin{claimmark}\n          Note that $d$-separation is symmetric: $A \\dPerp_G B \\given C \\iff B \\dPerp_G A \\given C$, by the same argument as for $\\sigma$-separation.\n          \\end{claimmark}\n    \\end{enumerate}\n\\end{Def}\n\\end{defmark}",
      "agent_registry": [],
      "time_needed_to_solve": 0,
      "addition_to_the_LN": ""
    },
