% LaTeX-template for FNWI exams,
% made by Jolien Kerssens (jolien.kerssens@student.uva.nl)

\NeedsTeXFormat{LaTeX2e}[1994/06/01]
\ProvidesPackage{FNWIexam}[2014/04/02 exam layout FNWI]
\RequirePackage{graphicx, eso-pic, kvoptions, kvoptions-patch}
\graphicspath{{./images/}}
\addtolength{\textheight}{1in}

% English is the standard language, open is the standard format for questions,
\newcommand{\firstPageHeader}{firstPageHeaderEN.png}
\newcommand{\pageHeader}{pageHeaderEN.png}
\newcommand{\questionCounting}{At each question is indicated how many points it is worth.}
\newcommand{\examPaper}{\textbf{each sheet} that you hand in. Also \textbf{number the pages}}

\DeclareStringOption{courseTitle}
\DeclareStringOption{progTitle}
\DeclareStringOption{examType}
\DeclareStringOption{examDate}
\DeclareStringOption{examTime}
\DeclareStringOption{toolsAllowed}
\DeclareStringOption{numPages}
\DeclareStringOption{numQuestions}
\DeclareStringOption{maxPoints}
\DeclareBoolOption[false]{dutch}
\DeclareBoolOption[false]{multipleChoice}
\ProcessKeyvalOptions*

\ifFNWIexam@dutch
\RequirePackage[dutch]{babel}
\else
\RequirePackage{babel}
\fi

% Front page
% English version
\ifFNWIexam@multipleChoice
    \renewcommand{\questionCounting}{Every question is worth one point, unless stated otherwise. Fill in the answer form by checking off the appropriate box completely with a \textbf{pencil}.}
    \renewcommand{\examPaper}{\textbf{your answer form}}
\fi

\newcommand{\firstPageText}{
    \mbox{}\vspace{30mm}
    
    {\Huge\noindent\FNWIexam@courseTitle}\\
    
    {\huge\noindent\FNWIexam@progTitle}
    \vspace{5mm}
    
    {\large\noindent\FNWIexam@examType}\\  
    {\large\noindent Date: \FNWIexam@examDate}\\
    {\large\noindent Time: \FNWIexam@examTime}

    \vspace{2mm}
    
    \noindent Number of pages: \FNWIexam@numPages \ (including front page)\\
    Number of questions: \FNWIexam@numQuestions\\
    Maximum number of points to earn: \FNWIexam@maxPoints\\
    \questionCounting
    \vspace{3mm}
    \hrule
    \vspace{3mm}    
    \noindent\textbf{\small BEFORE YOU START}
    \begin{itemize}
        \item Please \textbf{wait} until you are instructed to open the booklet.
        \item Check if your version of the exam is complete. 
        \item Write down \textbf{your name, student ID number}, and if applicable the \textbf{version number} on \examPaper .
        \item Your \textbf{mobile phone} has to be switched off and in the coat or bag. Your \textbf{coat and bag} must be under your table.
        \item \textbf{Tools allowed}: \FNWIexam@toolsAllowed .
    \end{itemize}
    \vspace{3mm}
    \hrule
    \vspace{3mm}
    \textbf{\small PRACTICAL MATTERS}
    \begin{itemize}
        \item The first 30 minutes and the last 15 minutes you are not allowed to leave the room, not even to visit the toilet. 
        \item You are obliged to identify yourself at the request of the examiner (or his representative) with a proof of your enrollment or a valid ID. 
        \item During the examination it is not permitted to visit the toilet, unless the proctor gives permission to do so.
        \item 15 minutes before the end, you will be warned that the time to hand in is approaching.
        \item If applicable, please fill out the evaluation form at the end of the exam. 
    \end{itemize}
    \vspace{3mm}
    \hrule
    \vspace{3mm}
    \textbf{\large Good luck!}
}

% Dutch version
\ifFNWIexam@dutch
    \renewcommand{\firstPageHeader}{firstPageHeaderNL.png}
    \renewcommand{\pageHeader}{pageHeaderNL.png}
    \renewcommand{\questionCounting}{Bij iedere vraag staat het bijbehorende aantal punten vermeld.}
    \renewcommand{\examPaper}{\textbf{elk vel papier} dat u inlevert en \textbf{nummer de pagina's}}

    \ifFNWIexam@multipleChoice
        \renewcommand{\questionCounting}{Iedere vraag is \'e\'en punt waard, tenzij anders wordt vermeld. Vul op het antwoordformulier het juiste antwoord in door het betreffende vakje helemaal in te kleuren met een \textbf{potlood}.}
        \renewcommand{\examPaper}{\textbf{uw antwoordformulier}}
    \fi
    
    \renewcommand{\firstPageText}{
    \mbox{}\vspace{30mm}
    
    {\Huge\noindent\FNWIexam@courseTitle}\\
    
    {\huge\noindent\FNWIexam@progTitle}
    \vspace{5mm}
    
    {\large\noindent\FNWIexam@examType}\\ 
    {\large\noindent Datum: \FNWIexam@examDate}\\
    {\large\noindent Tijd: \FNWIexam@examTime}

    \vspace{2mm}
    
    \noindent Aantal pagina's: \FNWIexam@numPages \ (inclusief voorblad)\\
    Aantal vragen: \FNWIexam@numQuestions\\
    Maximaal aantal te behalen punten: \FNWIexam@maxPoints\\
    \questionCounting
    \vspace{3mm}
    \hrule
    \vspace{3mm}
    \noindent\textbf{\small VOORDAT U BEGINT}
    \begin{itemize}
        \item \textbf{Wacht} tot u de instructie krijgt het boekje te openen.
        \item Controleer of uw versie van het tentamen compleet is.
        \item Schrijf \textbf{uw naam en studentnummer en indien van toepassing versienummer} op \examPaper. 
        \item U dient uw \textbf{mobiele telefoon} uit te schakelen en te bewaren in uw jas of tas. Uw \textbf{jas en tas} moeten onder uw tafel liggen.  
        \item \textbf{Toegestane hulpmiddelen}: \FNWIexam@toolsAllowed .
    \end{itemize}
    \vspace{3mm}
    \hrule
    \vspace{3mm}
    \textbf{\small HUISHOUDELIJKE MEDEDELINGEN}
    \begin{itemize}
        \item De eerste 30 minuten en de laatste 15 minuten mag u de zaal niet verlaten, ook niet voor het bezoeken van het toilet.  
        \item Op verzoek van de examinator (of diens vertegenwoordiger) moet u zich kunnen legitimeren met een bewijs van inschrijving of een geldig legitimatiebewijs.
        \item Tijdens het tentamen is toiletbezoek niet toegestaan, tenzij de surveillant hier toestemming voor geeft.
        \item 15 minuten voor het eind wordt u gewaarschuwd dat het inlevertijdstip nadert.
        \item Vul indien van toepassing na afloop van het tentamen alstublieft het evaluatieformulier in. 
    \end{itemize}
    \vspace{3mm}
    \hrule
    \vspace{3mm}
    \textbf{\large Succes!}
    }
\fi

% Commands for creating the exam
% Large banner
\newcommand\firstPagePic{
    \put(0,0){
        \parbox[b][\paperheight]{\paperwidth}{
        \vfill
        \centering
        \includegraphics[width=\paperwidth,height=\paperheight, keepaspectratio]{\firstPageHeader}
        \vfill
        }
    }
}

% Small banner
\newcommand\backgroundPic{
    \put(0,0){
        \parbox[b][\paperheight]{\paperwidth}{
        \vfill
        \centering
        \includegraphics[width=\paperwidth,height=\paperheight, keepaspectratio]{\pageHeader}
        \vfill
        }
    }
}

\newcommand{\makeFirstPage}{
    \AddToShipoutPicture{\firstPagePic}
    \thispagestyle{empty}
    \firstPageText
    \newpage
    % from here on, the smaller banner will be used
    \AddToShipoutPicture{\backgroundPic}
    \noindent
}

\endinput
