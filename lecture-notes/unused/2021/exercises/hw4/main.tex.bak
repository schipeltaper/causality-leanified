\flushleft\textbf{Topic: Markov kernels}


\section{Markov kernels}
\begin{enumerate} 
\item
    Show that a Markov kernel $K$ uniquely induces a measurable mapping:
    \[ \bar K:\, \Tcal \to \Pcal(\Wcal),\quad  \bar K(t)(A):=K(A|t),  \]% t \mapsto K(X|T=t) = \lp A \mapsto K(X \in A|T=t) \rp\]
    and vice versa. 
    Recall the definition  of 4.2.10 
     the $\sigma$-algebra of  $\Pcal(\Wcal)$ (see lecture notes).
\end{enumerate}

\section{Composition of Markov Kernels}
\begin{enumerate}
\item $Z, T, W$ are assumed to be finite discrete spaces with Markov kernels:\\
 
  \[Q(Z|W):\, \Wcal \dshto \Zcal,\quad (C,w) \mapsto Q(Z \in C|W=w),  \]
  \[K(W|T):\, \Tcal \dshto \Wcal,\quad (D,t) \mapsto K(W \in D|T=t),  \]

and stochastic matrices

\[\tilde Q = 
\begin{bmatrix}
0.1 & 0.7 & 0.2 \\
0.3 & 0   & 0.4 \\
0.6 & 0.3 & 0.4 \\
\end{bmatrix} 
\qquad
\tilde K = 
\begin{bmatrix}
0.2 & 0.1 & 0.6 \\
0.3 & 0.1 & 0 \\
0.5 & 0.8 & 0.4 \\
\end{bmatrix}\]

    
Compute the composition of Markov kernels $P(Z|T):=Q(Z|W) \circ K(W|T)$ i.e . compute the stochastic matrix $\tilde P$.

\item Prove the formula for the conditional Gaussian distribution ... [TBD: provide formula for conditional Gaussian].
%let the students prove the formula for the conditional Gaussians (by multiplying conditional with marginal and see that the joint comes out.

\item Consider the measurable spaces $T,W$ and $Z$ and the two continuous Markov kernels 

  \[K(W|T):\, \Tcal \dshto \Wcal,\quad (D,t) \mapsto K(W \in dw|T=t),  \]

  \[Q(Z|W):\, \Wcal \dshto \Zcal,\quad (C,w) \mapsto Q(Z \in dz|W=w),  \]

where $D \subseteq W$ and $C \subseteq Z$ are measurable subsets and $Q(Z|W)$ and $K(W|T)$ are Gaussian kernels. A Gaussian kernel is defined as:
 \[ k_t(x,y)= \frac{1}{\sqrt{2\pi}t}\exp \left(-(y-x)^2/(2t^2)\right) \]


Compute the composition $P(Z|T):=Q(Z|W) \circ K(W|T)$. Provide steps through your derivations.

\end{enumerate}

\begin{gradedsolution}
\begin{enumerate}
\item $\tilde P = \begin{bmatrix}
0.33 & 0.24 & 0.14 \\
0.26 & 0.35 & 0.34 \\
0.41 & 0.41 & 0.52 \\
\end{bmatrix}$.

\item Multiply conditional Gaussian p(x|y) with marginal p(y) and show that joint p(x,y) Gaussian comes out.

\item \begin{align*}
P(Z|T) &= \int_C Q(z \in dz| W=w) K(W\in dw|T=t) \\
 &= \int_C q(z|w)dz \; k(w|t)dw \\
 &= \int_C \frac{1}{\sqrt{2\pi}\sigma_q}\exp \left(-(z-w)^2/(2\sigma_q^2)\right) \; \frac{1}{\sqrt{2\pi}\sigma_k}\exp \left(-(w-t)^2/(2\sigma_k^2)\right)dzdw\\
 &=  \int_C \frac{1}{2\pi\sigma_q \sigma_k}\exp \left(-(z-w)^2/(2\sigma_q^2) - (w-t)^2/(2\sigma_k^2)\right)  dzdw\\
\end{align*} 

\end{enumerate}
\end{gradedsolution}


