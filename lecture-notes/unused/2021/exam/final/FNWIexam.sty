\ifFNWIexam@dutch
    \renewcommand{\firstPageHeader}{firstPageHeaderNL.png}
    \renewcommand{\pageHeader}{pageHeaderNL.png}
    \renewcommand{\questionCounting}{Bij iedere vraag staat het bijbehorende aantal punten vermeld.}
    \renewcommand{\examPaper}{\textbf{elk vel papier} dat u inlevert en \textbf{nummer de pagina's}}

    \ifFNWIexam@multipleChoice
        \renewcommand{\questionCounting}{Iedere vraag is \'e\'en punt waard, tenzij anders wordt vermeld. Vul op het antwoordformulier het juiste antwoord in door het betreffende vakje helemaal in te kleuren met een \textbf{potlood}.}
        \renewcommand{\examPaper}{\textbf{uw antwoordformulier}}
    \fi
    
    \renewcommand{\firstPageText}{
    \mbox{}\vspace{30mm}
    
    {\Huge\noindent\FNWIexam@courseTitle}\\
    
    {\huge\noindent\FNWIexam@progTitle}
    \vspace{5mm}
    
    {\large\noindent\FNWIexam@examType}\\ 
    {\large\noindent Datum: \FNWIexam@examDate}\\
    {\large\noindent Tijd: \FNWIexam@examTime}

    \vspace{2mm}
    
    \noindent Aantal pagina's: \FNWIexam@numPages \ (inclusief voorblad)\\
    Aantal vragen: \FNWIexam@numQuestions\\
    Maximaal aantal te behalen punten: \FNWIexam@maxPoints\\
    \questionCounting
    \vspace{3mm}
    \hrule
    \vspace{3mm}
    \noindent\textbf{\small INSTRUCTIES VOOR HET UPLOADEN}
    \begin{itemize}
        \item Schrijf op de voorpagina hoeveel bladzijden u inlevert.
        \item Informeer de surveillant dat u wilt inleveren.
        \item Maak een foto van uw uitwerkingen en uw \textbf{collegekaart}.
        \item Maak \'e\'en pdf. 
        \item Lever uw pdf in op Canvas.
        \item Informeer via de chat de surveillant dat u ingeleverd hebt.
        \item Wacht totdat de surveillant goedkeuring geeft dat uw bestand in orde is.
        \item U mag niet vertrekken van het Zoom tentamen voor \textbf{\FNWIexam@notLeaveBefore}.
    \end{itemize}
    \vspace{3mm}
    \hrule
    \vspace{3mm}
    \textbf{\small PRACTISCHE MEDEDELINGEN}
    \begin{itemize}
        \item \textbf{In geval van spoed:} bel \FNWIexam@emergencyName\ op \FNWIexam@emergencyPhone.
        \item\textbf{Toilet:} Steek uw (Zoom-blauwe) hand op en wacht totdat de surveillant toestemming geeft.
        \item \textbf{Vragen:} Steek uw (Zoom-blauwe) hand op en wacht totdat de surveillant reageert.
        \item \textbf{Chat:} Stuur altijd priv\'e berichten naar de surveillant via de chat.
        \item \textbf{Printen:} Het is toegestaan om het tentamen te printen.
    \end{itemize}
    \vspace{3mm}
    \hrule
    \vspace{3mm}
    \textbf{\large Succes!}
    }
\fi

% Commands for creating the exam
% Large banner
\newcommand\firstPagePic{
    \put(0,0){
        \parbox[b][\paperheight]{\paperwidth}{
        \vfill
        \centering
        \includegraphics[width=\paperwidth,height=\paperheight, keepaspectratio]{\firstPageHeader}
        \vfill
        }
    }
}

% Small banner
\newcommand\backgroundPic{
    \put(0,0){
        \parbox[b][\paperheight]{\paperwidth}{
        \vfill
        \centering
        \includegraphics[width=\paperwidth,height=\paperheight, keepaspectratio]{\pageHeader}
        \vfill
        }
    }
}

\newcommand{\makeFirstPage}{
    \AddToShipoutPicture{\firstPagePic}
    \thispagestyle{empty}
    \firstPageText
    \newpage
    % from here on, the smaller banner will be used
    \AddToShipoutPicture{\backgroundPic}
    \noindent
}

\endinput
