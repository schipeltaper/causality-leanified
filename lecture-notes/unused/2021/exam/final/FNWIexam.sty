% LaTeX-template for FNWI exams,
% made by Jolien Kerssens (jolien.kerssens@student.uva.nl)

\NeedsTeXFormat{LaTeX2e}[1994/06/01]
\ProvidesPackage{FNWIexam}[2014/04/02 exam layout FNWI]
\RequirePackage{graphicx, eso-pic, kvoptions, kvoptions-patch}
\RequirePackage{babel}
\graphicspath{{./images/}}
\addtolength{\textheight}{1in}

% English is the standard language, open is the standard format for questions,
\newcommand{\firstPageHeader}{firstPageHeaderEN.png}
\newcommand{\pageHeader}{pageHeaderEN.png}
\newcommand{\questionCounting}{At each question is indicated how many points it is worth.}
\newcommand{\examPaper}{\textbf{each sheet} that you hand in. Also \textbf{number the pages}}

\DeclareStringOption{courseTitle}
\DeclareStringOption{progTitle}
\DeclareStringOption{examType}
\DeclareStringOption{examDate}
\DeclareStringOption{examTime}
\DeclareStringOption{toolsAllowed}
\DeclareStringOption{numPages}
\DeclareStringOption{numQuestions}
\DeclareStringOption{maxPoints}
\DeclareStringOption{notLeaveBefore}
\DeclareStringOption{emergencyPhone}
\DeclareStringOption{emergencyName}
\DeclareBoolOption[false]{dutch}
\DeclareBoolOption[false]{multipleChoice}
\ProcessKeyvalOptions*

% Front page
% English version
\ifFNWIexam@multipleChoice
    \renewcommand{\questionCounting}{Every question is worth one point, unless stated otherwise. Fill in the answer form by checking off the appropriate box completely with a \textbf{pencil}.}
    \renewcommand{\examPaper}{\textbf{your answer form}}
\fi

\newcommand{\firstPageText}{
    \mbox{}\vspace{30mm}
    
    {\Huge\noindent\FNWIexam@courseTitle}\\
    
    {\huge\noindent\FNWIexam@progTitle}
    \vspace{5mm}
    
    {\large\noindent\FNWIexam@examType}\\  
    {\large\noindent Date: \FNWIexam@examDate}\\
    {\large\noindent Time: \FNWIexam@examTime}

    \vspace{2mm}
    
    \noindent Number of pages: \FNWIexam@numPages \ (including front page)\\
    Number of questions: \FNWIexam@numQuestions\\
    Maximum number of points to earn: \FNWIexam@maxPoints\\
    \questionCounting
    \vspace{3mm}
    \hrule
    \vspace{3mm}    
   \noindent\textbf{\small UPLOADING INSTRUCTIONS}
    \begin{itemize}
        \item On the front page write \textbf{how many pages} you are submitting.
        \item Inform the invigilator that you want to submit.
        \item Take a photo of your solutions and \textbf{ID card}.
        \item Make a \textbf{single pdf} file.
        \item Submit your pdf on Canvas.
        \item Inform the invigilator that you have submitted.
        \item \textbf{Wait} for the invigilator to confirm that your submission is accepted before you leave the Zoom session.
        \item You may not leave Zoom before \textbf{\FNWIexam@notLeaveBefore}.
    \end{itemize}
    \vspace{3mm}
    \hrule
    \vspace{3mm}
    \textbf{\small PRACTICAL ANNOUNCEMENTS}
    \begin{itemize}
        \item \textbf{Emergency number:} call \FNWIexam@emergencyName\ on \FNWIexam@emergencyPhone.
        \item\textbf{Bathroom:} raise your (Zoom-blue) hand and wait to be given permission. 
        \item \textbf{Questions:} raise your (Zoom-blue) hand and wait for the invigilator to come to you.
        \item \textbf{Chat:} Send only \textbf{private messages} to the invigilators.
        \item \textbf{Printing:} You are allowed to print the exam questions.
    \end{itemize}
    \vspace{3mm}
    \hrule
    \vspace{3mm}
    \textbf{\large Good luck!}
}

